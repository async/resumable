# Async-await runtime-agnostic command policy.
#
# Shared framework packages must run across Node, Deno, Bun, workers, and
# browser-hosted tooling through host adapters. Prefer Web APIs, `pathe`, and
# `ufo`; do not add Node-only imports or assumptions to compiler/runtime core.

prefix_rule(
    pattern = ["rg", "-n"],
    decision = "allow",
    justification = "Read-only runtime-portability scans are safe.",
    match = [
        "rg -n \"from ['\\\"]node:\" .",
        "rg -n \"from ['\\\"](fs|path|url|crypto)['\\\"]\" .",
        "rg -n \"require\\(['\\\"](node:)?(fs|path|url|crypto)['\\\"]\\)\" .",
        "rg -n \"process\\.|Buffer\\b|__dirname|__filename\" .",
    ],
)

prefix_rule(
    pattern = [["pnpm", "npm", "yarn", "bun"], ["add", "install", "i", "update"]],
    decision = "prompt",
    justification = "Dependency changes must be reviewed for runtime portability; prefer pathe/ufo and adapter-injected host capabilities.",
    match = [
        "pnpm add pathe",
        "pnpm add ufo",
        "pnpm add fs-extra",
        "npm i pathe",
        "yarn add ufo",
        "bun add fs-extra",
    ],
    not_match = [
        "pnpm test",
        "pnpm build",
        "npm run test",
        "yarn build",
        "bun test",
    ],
)
